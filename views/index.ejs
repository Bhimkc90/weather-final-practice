<!DOCTYPE html>
<html>
<head>
    <title>Weather Search</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <h1>Weather Search</h1>

    <form action="/search" method="GET" class="search-box">

        <div class="city-row">
            <input 
                type="text" 
                name="city" 
                placeholder="Search: City Name" 
                required
            >
        </div>
    
        <div class="options-row">
            <div>
                <label>Units:</label>
                <select name="units">
                    <option value="metric">Celsius</option>
                    <option value="imperial">Farenheit</option>
                </select>
            </div>
    
            <div>
                <label>Lang:</label>
                <select name="lang">
                    <option value="english">English</option>
                    <option value="spanish">Spanish</option>
                </select>
            </div>
        </div>
    
        <div class="type-row">
            <label>Type:</label>
            <select name="type">
                <option value="today">1-Day</option>
                <option value="5day">5-Days</option>
            </select>
        </div>
    
        <button type="submit">SUBMIT</button>
    
    </form>

    <hr>

    <% if (error) { %>
        <h2><%= error %></h2>
    <% } %>

    <% if (weather && type === "today") { %>

        <div class="weather-card">
        
            <h2><%= weather.name %></h2>
        
            <img
                src="https://openweathermap.org/img/wn/<%= weather.weather[0].icon %>@2x.png"
                alt="Weather Icon"
            >
        
            <h3>
                <%= weather.main.temp %>°
                <%= units === "imperial" ? "F" : "C" %>
            </h3>
        
            <p><strong><%= weather.weather[0].description %></strong></p>
        
            <p>Humidity: <%= weather.main.humidity %>%</p>
        
            <p>Wind Speed: <%= weather.wind.speed %></p>
        
        </div>
        
        <% } %>

    <% if (weather && type === "5day") { %>

        <h2 class="result-title">5 Day Forecast for <%= weather.city.name %></h2>
    
        <div class="forecast-grid">
            <% weather.list.filter((item, index) => index % 8 === 0).slice(0, 5).forEach(function(item) { %>
    
                <div class="forecast-card">
                    <h3><%= item.dt_txt.split(" ")[0] %></h3>
    
                    <img 
                        src="https://openweathermap.org/img/wn/<%= item.weather[0].icon %>@2x.png" 
                        alt="Weather Icon"
                    >
    
                    <p><strong><%= item.main.temp %>°<%= units === "imperial" ? "F" : "C" %></strong></p>
                    <p><%= item.weather[0].description %></p>
                    <p>Humidity: <%= item.main.humidity %>%</p>
                    <p>Wind: <%= item.wind.speed %></p>
                </div>
    
            <% }) %>
        </div>
    
    <% } %>
    
</body>
</html>